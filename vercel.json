{
  "env": {
    "VITE_SITE_URL": "https://www.jpairport.jp"
  },
  "redirects": [
    {
      "source": "/:lang(en|zh-hk|ar)/how-it-works",
      "destination": "/:lang#booking-process",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/en",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/en",
      "destination": "/en/index.html"
    },
    {
      "source": "/zh-hk",
      "destination": "/zh-hk/index.html"
    },
    {
      "source": "/ar",
      "destination": "/ar/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/:lang(en|zh-hk|ar)/:page(services|routes|faq|request-quote|privacy|terms)",
      "destination": "/:lang/:page/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ]
}
